# ═══════════════════════════════════════════════════════════════
# Gemini Runtime 配置
# ═══════════════════════════════════════════════════════════════
# 首次使用：复制本文件为 .env，然后按需修改配置
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Chrome ────────────────────────────────────────────────────
# Chrome 可执行文件路径
#   留空则自动从默认安装路径查找（推荐先留空，失败再指定）
#   按平台自动检测的默认路径：
#     Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
#     macOS:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#     Linux:   /usr/bin/google-chrome
#   如果需要手动指定，示例：
#     CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
#     CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#     CHROME_PATH=/usr/bin/google-chrome
CHROME_PATH=

# Chrome 用户数据目录
#   用于持久化登录态，首次启动后自动创建
#   建议使用绝对路径，避免冷启动找不到 Profile
#   示例：USER_DATA_DIR=C:/Users/YourName/demo/browser-automation-architect/userdata
USER_DATA_DIR=./userdata


# ── CDP（Chrome DevTools Protocol）─────────────────────────────
# Chrome 远程调试端口
#   默认 9222，通常无需修改。多个项目同时使用时需改不同端口
REMOTE_DEBUGGING_PORT=9222


# ── 代理 ──────────────────────────────────────────────────────
# 代理服务器（中国用户 必填，否则无法访问 Gemini）
#   支持协议：http / https / socks5
#   常用的代理客户端：Clash Meta / v2ray / sing-box 等默认端口 7890
#   如果你用其他代理工具，请修改为实际端口号
PROXY_SERVER=http://127.0.0.1:7890
# PROXY_SERVER=socks5://127.0.0.1:7890


# ── 对话 ──────────────────────────────────────────────────────
# Gemini 网页地址（通常无需修改）
TARGET_URL=https://gemini.google.com/app

# HEADLESS 已废弃
#   Chrome 默认以最小化方式运行在后台，不干扰用户操作
#   需要查看浏览器时，给 chat.py 加 --headed 参数
HEADLESS=false

# 单次对话超时（秒）
#   包含模型切换 + 等待 AI 回复的完整时间
#   如果经常使用扩展思考，建议设为 180（3 分钟）
CHAT_TIMEOUT=120


# ── 模型 ──────────────────────────────────────────────────────
# 模型名（推荐使用家族名，运行时自动匹配菜单项）
#   支持以下值（大小写不敏感）：
#
#   Pro        → Gemini 3.1 Pro（高级数学推理）
#   Flash      → Gemini 3.5 Flash（全方位助手，快速）
#   Flash-Lite → Gemini 3.1 Flash-Lite（快速回答，最低开销）
#
#   指定家族名即可，系统会自动匹配菜单中的完整模型名
#   示例：MODEL_NAME=Pro  → 自动选择 "3.1 Pro 高级数学与代码"
MODEL_NAME=Pro

# 思考等级（仅 Pro 系列有效，Flash/Lite 自动忽略此项）
#   extended → 扩展思考（更深入的推理，首回复可能需 30-60s）
#   standard → 标准思考（常规回复速度）
THINKING_LEVEL=extended


# ── 日志 ──────────────────────────────────────────────────────
# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
